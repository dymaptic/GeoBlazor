@inherits TestRunnerBase

@{
    base.BuildRenderTree(__builder);
}

@* ReSharper disable once InconsistentNaming *@

@code {

    [TestMethod]
    public async Task TestCanRenderWMSLayerWithFeatureInfoFormats(Action renderHandler,
        Action<LayerViewCreateEvent> layerViewCreated)
    {
#pragma warning disable GeoBlazor_Untested
        WMSLayer? layer = null;

        AddMapRenderFragment(
            @<SceneView class="map-view" 
                        OnViewRendered="renderHandler"
                        OnLayerViewCreate="layerViewCreated">
                <Map Ground="world-elevation">
                    <WMSLayer @ref="layer"
                              Url="https://ows.terrestris.de/osm/service"
                              SpatialReference="new SpatialReference(102100)">
                        <WMSSublayer Name="TOPO-WMS"/>
                    </WMSLayer>
                </Map>
        </SceneView>);
        await WaitForMapToRender(timeoutInSeconds: 90);
        
        LayerViewCreateEvent createEvent = await WaitForLayerToRender<WMSLayer>();
        Assert.IsInstanceOfType<WMSLayer>(createEvent.Layer);
        WMSLayer createdLayer = (WMSLayer)createEvent.Layer;
        Assert.AreEqual(layer?.Id, createdLayer.Id);
        
        await AssertJavaScript("assertLayerExists", args: "wms");
#pragma warning restore GeoBlazor_Untested
    }
    
    [TestMethod]
    public async Task TestWMSLayerSpatialReference(Action renderHandler,
        Action<LayerViewCreateEvent> layerViewCreated)
    {
        WMSLayer? layer = null;

        AddMapRenderFragment(
            @<SceneView class="map-view" 
                        OnViewRendered="renderHandler"
                        OnLayerViewCreate="layerViewCreated">
                <Map>
                    <WMSLayer @ref="layer"
                              Url="https://ows.terrestris.de/osm/service" >
                        <WMSSublayer Name="TOPO-WMS"/>
                    </WMSLayer>
                </Map>
            </SceneView>);
        await WaitForMapToRender(timeoutInSeconds: 90);
        LayerViewCreateEvent createEvent = await WaitForLayerToRender<WMSLayer>();
        Assert.IsInstanceOfType<WMSLayer>(createEvent.Layer);
        WMSLayer createdLayer = (WMSLayer)createEvent.Layer;
        Assert.AreEqual(layer?.Id, createdLayer.Id);
        Assert.IsTrue(layer?.SpatialReference == SpatialReference.Wgs84);
    }

    [TestMethod]
    public async Task TestWMSLayerWithLatLongAndZoom(Action renderHandler,
            Action<LayerViewCreateEvent> layerViewCreated)
    {
        MapView? view = null;

        AddMapRenderFragment(@<MapView @ref="view" class="map-view"
                                       Latitude="51.4" Longitude="0.0"
                                       Zoom="11"
                                       OnViewRendered="renderHandler"
                                       OnLayerViewCreate="layerViewCreated">
                                 <Map>
                                     <Basemap>
                                         <WMSLayer Url="https://ows.terrestris.de/osm/service">
                                             <WMSSublayer Name="TOPO-WMS"/>
                                         </WMSLayer>
                                     </Basemap>
                                 </Map>
                             </MapView>);
        await WaitForMapToRender(timeoutInSeconds: 90);
        await WaitForLayerToRender<WMSLayer>();
        Point? center = await view!.GetCenter();
        Assert.IsNotNull(center);
        Assert.IsTrue(Math.Abs(0.0 - center.Longitude!.Value) < 0.001);
        Assert.IsTrue(Math.Abs(51.4 - center.Latitude!.Value) < 0.001);
        double? zoom = await view!.GetZoom();
        Assert.IsNotNull(zoom);

        // Zoom is not supported in WMS layers, so this will return -1 even though we set 11
        Assert.AreEqual(-1, zoom);
    }

    [TestMethod]
    public async Task TestWMSLayerWithLatLongAndScale(Action renderHandler,
        Action<LayerViewCreateEvent> layerViewCreated)
    {
        MapView? view = null;

        AddMapRenderFragment(@<MapView @ref="view" class="map-view"
                                       Latitude="51.4" Longitude="0.0"
                                       Scale="288895.277144"
                                       OnViewRendered="renderHandler"
                                       OnLayerViewCreate="layerViewCreated">
                                 <Map>
                                     <Basemap>
                                         <WMSLayer Url="https://ows.terrestris.de/osm/service">
                                             <WMSSublayer Name="TOPO-WMS"/>
                                         </WMSLayer>
                                     </Basemap>
                                 </Map>
                             </MapView>);
        await WaitForMapToRender(timeoutInSeconds: 90);
        await WaitForLayerToRender<WMSLayer>();
        Point? center = await view!.GetCenter();
        Assert.IsNotNull(center);
        Assert.IsTrue(Math.Abs(0.0 - center.Longitude!.Value) < 0.001);
        Assert.IsTrue(Math.Abs(51.4 - center.Latitude!.Value) < 0.001);
        double? scale = await view!.GetScale();
        Assert.IsNotNull(scale);

        // Scale works, even though Zoom is not supported in WMS layers
        Assert.IsTrue(Math.Abs(288895.277144 - scale.Value) < 0.001);
    }
}